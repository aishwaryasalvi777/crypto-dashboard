# --- Authentication (temporary, env-based credentials) ---
# Secret used to sign the session cookie. Use a long random string in production.
SESSION_SECRET=dev-secret-change-me-please-0123456789

# Temporary login credentials. Real auth provider integrated later.
AUTH_USERNAME=admin
AUTH_PASSWORD=password

# --- Crypto data provider ---
# "coinbase" (live, default), "coingecko" (live + 24h change & sparklines), or
# "mock" (offline demo data, no network).
CRYPTO_PROVIDER=coinbase

# Coinbase config (used when CRYPTO_PROVIDER=coinbase).
# The public /v2/exchange-rates endpoint needs NO key; the key field is reserved for
# future authenticated features and can be left blank.
COINBASE_API_BASE=https://api.coinbase.com
COINBASE_API_KEY=

# CoinGecko config (used when CRYPTO_PROVIDER=coingecko)
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# Auto-refresh interval in seconds (10–300).
REFRESH_SECONDS=30
